\newlabel{tab:chunking}{{1}{11}{Chunk-size ablation: Recall@12 and warm latency at $K=12$, no reranking, overlap fixed at 30~words}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Pareto-optimal retrieval configurations on HotpotQA (500 queries, dev\textsubscript  {distractor}, $K\in \{5,8,12\}$, overlap fixed at 30~words). Recall@$K$ with 95\,\% Wilson CI. Cost column reflects local CPU inference (zero API spend). Statistical comparisons at $K=12$: Hybrid+rerank vs.\ Hybrid no-rerank ($\Delta = +0.027$, $z = 1.45$, $p = 0.148$, not significant); Hybrid no-rerank vs.\ Dense no-rerank ($\Delta = +0.052$, $z = 2.40$, $p = 0.017$).}}{11}{table.2}\protected@file@percent }
\newlabel{tab:pareto}{{2}{11}{Pareto-optimal retrieval configurations on HotpotQA (500 queries, dev\textsubscript {distractor}, $K\in \{5,8,12\}$, overlap fixed at 30~words). Recall@$K$ with 95\,\% Wilson CI. Cost column reflects local CPU inference (zero API spend). Statistical comparisons at $K=12$: Hybrid+rerank vs.\ Hybrid no-rerank ($\Delta = +0.027$, $z = 1.45$, $p = 0.148$, not significant); Hybrid no-rerank vs.\ Dense no-rerank ($\Delta = +0.052$, $z = 2.40$, $p = 0.017$)}{table.2}{}}
\@writefile{toc}{\contentsline {paragraph}{Key finding: generation dominates retrieval latency.}{11}{section*.14}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.6}Corpus-Scale Cold-Start Analysis}{11}{subsection.6.6}\protected@file@percent }
\newlabel{sec:results_scale}{{6.6}{11}{Corpus-Scale Cold-Start Analysis}{subsection.6.6}{}}
\@writefile{toc}{\contentsline {paragraph}{Linear scaling.}{11}{section*.15}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Cold-start latency vs.\ corpus size (log--log scale) for BM25 and dense retrieval over 5 timing repeats each (error bars = $\pm 1$ std). Dense cold-start grows linearly with corpus size (slope $\approx 1$ in log--log), reaching $\approx $1.6\,minutes (96\,s) at 50K passages. BM25 cold-start also grows linearly but 48--75$\times $ slower (corpus-size dependent), remaining $<$2.1\,s at 50K passages. The ordering never crosses: BM25 cold-start is always faster than dense for any corpus size evaluated.}}{12}{figure.5}\protected@file@percent }
\newlabel{fig:cold_scale}{{5}{12}{Cold-start latency vs.\ corpus size (log--log scale) for BM25 and dense retrieval over 5 timing repeats each (error bars = $\pm 1$ std). Dense cold-start grows linearly with corpus size (slope $\approx 1$ in log--log), reaching $\approx $1.6\,minutes (96\,s) at 50K passages. BM25 cold-start also grows linearly but 48--75$\times $ slower (corpus-size dependent), remaining $<$2.1\,s at 50K passages. The ordering never crosses: BM25 cold-start is always faster than dense for any corpus size evaluated}{figure.5}{}}
\@writefile{toc}{\contentsline {paragraph}{No crossover.}{12}{section*.16}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Practical breakpoints.}{12}{section*.17}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.7}LegalBench-RAG: Span-Level Retrieval Evaluation}{12}{subsection.6.7}\protected@file@percent }
\newlabel{sec:legalbench_results}{{6.7}{12}{LegalBench-RAG: Span-Level Retrieval Evaluation}{subsection.6.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces LegalBench-RAG PrivacyQA span-level retrieval results ($n=194$ queries, $K=12$, chunk\,=\,250 words). Recall@$K$ is computed at the character-span level: a retrieved chunk counts as a true positive only if its character range overlaps the annotated supporting span. Wilson 95\,\% CIs reported. On this domain, dense retrieval substantially outperforms BM25 (gap 0.509, $z=10.06$, $p<0.001$), reversing the domain pattern observed on HotpotQA. Pairwise: Dense--Hybrid ($\Delta = 0.076$, $z = 1.74$, $p = 0.082$, not significant); Hybrid--BM25 ($\Delta = 0.433$, $z = 8.53$, $p < 0.001$). Precision@12 = (chunks with span overlap in top-12)\,/\,12; low values reflect the strict character-span criterion and multi-document corpus (7 policies, 127 chunks).}}{13}{table.3}\protected@file@percent }
\newlabel{tab:legalbenchrag}{{3}{13}{LegalBench-RAG PrivacyQA span-level retrieval results ($n=194$ queries, $K=12$, chunk\,=\,250 words). Recall@$K$ is computed at the character-span level: a retrieved chunk counts as a true positive only if its character range overlaps the annotated supporting span. Wilson 95\,\% CIs reported. On this domain, dense retrieval substantially outperforms BM25 (gap 0.509, $z=10.06$, $p<0.001$), reversing the domain pattern observed on HotpotQA. Pairwise: Dense--Hybrid ($\Delta = 0.076$, $z = 1.74$, $p = 0.082$, not significant); Hybrid--BM25 ($\Delta = 0.433$, $z = 8.53$, $p < 0.001$). Precision@12 = (chunks with span overlap in top-12)\,/\,12; low values reflect the strict character-span criterion and multi-document corpus (7 policies, 127 chunks)}{table.3}{}}
