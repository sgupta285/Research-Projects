\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}Quality vs.\ Warm-Start Latency (Fixed $K=12$)}{6}{subsection.6.1}\protected@file@percent }
\newlabel{sec:results_latency}{{6.1}{6}{Quality vs.\ Warm-Start Latency (Fixed $K=12$)}{subsection.6.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Pareto frontier of Recall@12 vs.\ warm-start latency at fixed $K=12$. Circle\,=\,BM25, square\,=\,dense, triangle\,=\,hybrid; solid-bordered markers are Pareto-optimal. Error bars show 95\,\% Wilson CIs. Dense no-rerank configurations (8.9--9.0\,ms) achieve both higher recall \emph  {and} lower latency than BM25 (10.7\,ms), placing all BM25 configurations off the warm Pareto frontier---a reversal visible only when cold-start costs are included (Figure~\ref {fig:cold_warm}). Note: reranked configs ($>$60\,ms) appear at the right edge.}}{7}{figure.1}\protected@file@percent }
\newlabel{fig:pareto_latency}{{1}{7}{Pareto frontier of Recall@12 vs.\ warm-start latency at fixed $K=12$. Circle\,=\,BM25, square\,=\,dense, triangle\,=\,hybrid; solid-bordered markers are Pareto-optimal. Error bars show 95\,\% Wilson CIs. Dense no-rerank configurations (8.9--9.0\,ms) achieve both higher recall \emph {and} lower latency than BM25 (10.7\,ms), placing all BM25 configurations off the warm Pareto frontier---a reversal visible only when cold-start costs are included (Figure~\ref {fig:cold_warm}). Note: reranked configs ($>$60\,ms) appear at the right edge}{figure.1}{}}
\@writefile{toc}{\contentsline {paragraph}{Statistical comparisons.}{7}{section*.8}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Interpretation.}{7}{section*.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Recall@$K$ vs.\ per-query reranking latency overhead at fixed $K=12$. Triangles indicate reranked configurations (retrieve $2K=24$ candidates, cross-encode all 24 pairs, return top $K=12$); other markers are non-reranked. The cross-encoder (\texttt  {ms-marco-MiniLM-L-6-v2}) adds 42--47\,ms per query on CPU at zero API cost. The $2K$ pool expansion \emph  {does} improve Recall@12: BM25+rerank 0.846 vs.\ 0.797 ($+0.049$), Dense+rerank 0.881 vs.\ 0.838 ($+0.043$), Hybrid+rerank 0.917 vs.\ 0.890 ($+0.027$). The Pareto-optimal quality configuration is Hybrid+rerank (Recall@12\,=\,0.917, 64.4\,ms).}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:pareto_cost}{{2}{8}{Recall@$K$ vs.\ per-query reranking latency overhead at fixed $K=12$. Triangles indicate reranked configurations (retrieve $2K=24$ candidates, cross-encode all 24 pairs, return top $K=12$); other markers are non-reranked. The cross-encoder (\texttt {ms-marco-MiniLM-L-6-v2}) adds 42--47\,ms per query on CPU at zero API cost. The $2K$ pool expansion \emph {does} improve Recall@12: BM25+rerank 0.846 vs.\ 0.797 ($+0.049$), Dense+rerank 0.881 vs.\ 0.838 ($+0.043$), Hybrid+rerank 0.917 vs.\ 0.890 ($+0.027$). The Pareto-optimal quality configuration is Hybrid+rerank (Recall@12\,=\,0.917, 64.4\,ms)}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Quality vs.\ Reranking Overhead}{8}{subsection.6.2}\protected@file@percent }
\newlabel{sec:results_cost}{{6.2}{8}{Quality vs.\ Reranking Overhead}{subsection.6.2}{}}
\@writefile{toc}{\contentsline {paragraph}{2K pool expansion improves Recall@K.}{8}{section*.10}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Latency--quality tradeoff.}{8}{section*.11}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Total cold-start latency $T_{\mathrm  {cold}}$ (log scale) vs.\ warm-start mean latency. The dashed diagonal marks $T_{\mathrm  {cold}} = T_{\mathrm  {warm}}$. BM25 configurations cluster at 133--136\,ms cold (index construction only) / 10.7\,ms warm (ratio $\approx \!13\times $). Dense and hybrid no-rerank configurations cluster at 11.5--14.4\,\textit  {seconds} cold / 8.9--23.6\,ms warm (ratio $\approx \!500$--$1{,}600\times $). At this corpus scale, dense cold-start is 85--108$\times $ higher than BM25 cold-start in absolute terms; the dominant cost is corpus encoding (90--92\,\% of cold-start, varying by chunk size), not model loading ($\approx \!8\,\%$).}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:cold_warm}{{3}{9}{Total cold-start latency $T_{\mathrm {cold}}$ (log scale) vs.\ warm-start mean latency. The dashed diagonal marks $T_{\mathrm {cold}} = T_{\mathrm {warm}}$. BM25 configurations cluster at 133--136\,ms cold (index construction only) / 10.7\,ms warm (ratio $\approx \!13\times $). Dense and hybrid no-rerank configurations cluster at 11.5--14.4\,\textit {seconds} cold / 8.9--23.6\,ms warm (ratio $\approx \!500$--$1{,}600\times $). At this corpus scale, dense cold-start is 85--108$\times $ higher than BM25 cold-start in absolute terms; the dominant cost is corpus encoding (90--92\,\% of cold-start, varying by chunk size), not model loading ($\approx \!8\,\%$)}{figure.3}{}}
